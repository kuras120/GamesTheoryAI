<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>

<GridPane alignment="center" hgap="10" vgap="10" xmlns="http://javafx.com/javafx/10.0.2-internal"
          xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.games.theory.tictactoe.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <rowConstraints>
        <RowConstraints prefHeight="600.0" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="50.0" prefHeight="50.0"/>
    </rowConstraints>
    <columnConstraints>
        <ColumnConstraints minWidth="600.0" prefWidth="600.0"/>
        <ColumnConstraints hgrow="ALWAYS" minWidth="360.0" prefWidth="500.0"/>
    </columnConstraints>

    <GridPane fx:id="table" alignment="CENTER" gridLinesVisible="true">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="150.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="150.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="150.0" vgrow="SOMETIMES"/>
            <RowConstraints minHeight="10.0" prefHeight="150.0" vgrow="SOMETIMES"/>
        </rowConstraints>
    </GridPane>

    <GridPane GridPane.rowIndex="1">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
        </columnConstraints>
        <Button maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#resetGame"
                text="Reset" GridPane.columnIndex="2"/>
    </GridPane>

    <VBox fillWidth="true" prefWidth="500.0" spacing="10.0" GridPane.columnIndex="1" GridPane.rowSpan="2">
        <HBox alignment="CENTER_RIGHT" minHeight="50.0" spacing="10.0">
            <Label fx:id="aiStatusLabel" maxWidth="260.0" text="Preparing AI…" textAlignment="RIGHT"
                   wrapText="true"/>
            <CheckBox fx:id="aiCheckbox" disable="true" mnemonicParsing="false" text="AI"/>
        </HBox>
        <Label alignment="CENTER_LEFT" maxWidth="Infinity" text="Game activity"/>
        <ListView fx:id="activityFeed" maxWidth="Infinity" prefHeight="500.0" VBox.vgrow="ALWAYS"/>
        <TextArea fx:id="pointsField" disable="true" maxHeight="70.0" maxWidth="Infinity" minHeight="70.0"
                  prefHeight="70.0"/>
    </VBox>
</GridPane>
